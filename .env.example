# ─── Turso (Production) ────────────────────────────────────────────────────────
# Get these from: https://app.turso.tech → your database → Connect
# Leave empty during local development (falls back to local SQLite file)

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ─── Local development ─────────────────────────────────────────────────────────
# No extra config needed for local dev. The app uses the local SQLite file
# at prisma/dev.db automatically when TURSO_DATABASE_URL is not set.

# ─── AI Description Generation ─────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# Optional: if not set, a fallback description is used
ANTHROPIC_API_KEY=your-anthropic-api-key-here
